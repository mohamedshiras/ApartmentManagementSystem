<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F6FB"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:background="#ffffff">
                <!-- Back arrow -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_back"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#0D47A1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back to feed" />

                <!-- Title -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Reservations"
                    android:textColor="#214177"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Calendar icon -->
                <ImageView
                    android:id="@+id/btnReservationHistory"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_calendar_month"
                    android:tint="#214177"
                    android:background="@drawable/bg_icon_circle"
                    android:contentDescription="Reservation History"
                    tools:ignore="UseAppTint" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp">

            <!-- Section Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Amenities"
                android:textColor="#214177"
                android:textSize="13sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="16dp" />

            <!-- ═══════════════ POOL CARD ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#2A5090">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Pool Image -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <ImageView
                            android:id="@+id/imgPool"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_pool"
                            android:contentDescription="Swimming Pool" />

                        <!-- Gradient overlay -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/gradient_image_overlay" />

                        <!-- Availability Badge -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="14dp"
                            android:background="@drawable/bg_badge_available"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_dot_green"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Available"
                                android:textColor="#2ECC71"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/gradient_image_overlay" />

                    </FrameLayout>

                    <!-- Pool Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Swimming Pool"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Enjoy a refreshing swim in our outdoor infinity pool with stunning views. Open daily from 6:00 AM to 10:00 PM."
                            android:textColor="#82A6CB"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="16dp" />

                        <!-- Time & Capacity row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="6AM – 10PM"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Max 20 guests"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Book Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBookPool"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Book Pool"
                            android:textColor="#0D1B35"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            app:backgroundTint="#ffffff"
                            app:cornerRadius="12dp"
                            app:elevation="0dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ GYM CARD ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGym"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#2A5090">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Gym Image -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <ImageView
                            android:id="@+id/imgGym"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_gym"
                            android:contentDescription="Fitness Center" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="14dp"
                            android:background="@drawable/bg_badge_available"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_dot_green"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Available"
                                android:textColor="#2ECC71"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                    </FrameLayout>

                    <!-- Gym Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fitness Center"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Fully equipped gym with cardio machines, free weights, and strength training equipment. Personal trainers available on request."
                            android:textColor="#8A9DC0"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5AM – 11PM"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Max 15 guests"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBookGym"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Book Gym"
                            android:textColor="#0D1B35"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            app:backgroundTint="#ffffff"
                            app:cornerRadius="12dp"
                            app:elevation="0dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ RESTAURANT CARD ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRestaurant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#2A5090">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Restaurant Image -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <ImageView
                            android:id="@+id/imgRestaurant"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_restaurant"
                            android:contentDescription="Restaurant" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/gradient_image_overlay" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="14dp"
                            android:background="@drawable/bg_badge_busy"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_dot_orange"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Busy Now"
                                android:textColor="#F39C12"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                    </FrameLayout>

                    <!-- Restaurant Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restaurant &amp; Dining"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Reserve a table at our rooftop restaurant. Enjoy fine dining with panoramic views. A la carte menu available all day."
                            android:textColor="#8A9DC0"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="7AM – 11PM"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="5dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="A La Carte"
                                    android:textColor="#8A9DC0"
                                    android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBookRestaurant"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Reserve Table"
                            android:textColor="#0D1B35"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            app:backgroundTint="#ffffff"                           app:cornerRadius="12dp"
                            app:elevation="0dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>