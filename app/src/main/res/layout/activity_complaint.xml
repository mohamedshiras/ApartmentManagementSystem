<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_complaint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    tools:context=".ComplaintActivity">

    <!-- ══════════════════════════════════
         TOP APP BAR
         ══════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <!-- Back button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF4FB"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#214177" />
            </androidx.cardview.widget.CardView>

            <!-- Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Complaints"
                android:textColor="#214177"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Tab strip -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:tabIndicatorColor="#214177"
            app:tabIndicatorHeight="3dp"
            app:tabSelectedTextColor="#214177"
            app:tabTextColor="#94A3B8"
            app:tabTextAppearance="@android:style/TextAppearance.Small"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolved" />

        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════
         MAIN SCROLL
         ══════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ SUMMARY STATS CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#214177">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Badge pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#2A5090"
                        android:paddingStart="10dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="14dp">
                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="#22C55E"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unit 4B · Block C"
                            android:textColor="#BDD8F1"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Active Cases -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Cases"
                                android:textColor="#82A6CB"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/textActiveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textColor="#82A6CB"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:background="#3667A6" />

                        <!-- Resolved -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Resolved"
                                android:textColor="#82A6CB"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/textResolvedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textColor="#82A6CB"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:background="#3667A6" />

                        <!-- Pending -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="#82A6CB"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />
                            <TextView
                                android:id="@+id/textPendingCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textColor="#82A6CB"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ══ SECTION HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/textListHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Reports"
                    android:textColor="#214177"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all →"
                    android:textColor="#3667A6"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── COMPLAINT 1 — Noise · Under Review ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/complaintItem1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#A78BFA">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:text="JD"
                                android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="James D. · Unit 5A" android:textColor="#1E293B"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1 day ago" android:textColor="#94A3B8" android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="22dp"
                            app:cardCornerRadius="11dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFE4E6">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:text="⚠️ Complaint" android:textColor="#E11D48"
                                android:textSize="10sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Inline status card -->
                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:cardCornerRadius="14dp" app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Noisy neighbour — late night"
                                    android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_marginBottom="2dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Request #CMP-0018 · Block C"
                                    android:textColor="#94A3B8" android:textSize="11sp" />
                            </LinearLayout>
                            <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="24dp"
                                app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#DBEAFE">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:text="Under Review" android:textColor="#3667A6"
                                    android:textSize="10sp" android:textStyle="bold" />
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginBottom="10dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_thumb_up" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12" android:textColor="#82A6CB" android:textSize="12sp"
                            android:layout_marginEnd="14dp" />
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_comment" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="6 comments" android:textColor="#82A6CB" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="View Details" android:textColor="#3667A6" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── COMPLAINT 2 — Parking · In Progress ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/complaintItem2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#82A6CB">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:text="SR"
                                android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Sarah R. · Unit 2A" android:textColor="#1E293B"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="3 hours ago" android:textColor="#94A3B8" android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="22dp"
                            app:cardCornerRadius="11dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFE4E6">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:text="⚠️ Complaint" android:textColor="#E11D48"
                                android:textSize="10sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:cardCornerRadius="14dp" app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Unauthorized parking — Bay 12"
                                    android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_marginBottom="2dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Request #CMP-0017 · Block B"
                                    android:textColor="#94A3B8" android:textSize="11sp" />
                            </LinearLayout>
                            <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="24dp"
                                app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#FEF3C7">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:text="In Progress" android:textColor="#D97706"
                                    android:textSize="10sp" android:textStyle="bold" />
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginBottom="10dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_thumb_up" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="7" android:textColor="#82A6CB" android:textSize="12sp"
                            android:layout_marginEnd="14dp" />
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_comment" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="3 comments" android:textColor="#82A6CB" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="View Details" android:textColor="#3667A6" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── COMPLAINT 3 — Littering · Pending ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/complaintItem3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#5B8FF9">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:text="MK"
                                android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Mike K. · Unit 3C" android:textColor="#1E293B"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="2 days ago" android:textColor="#94A3B8" android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="22dp"
                            app:cardCornerRadius="11dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFE4E6">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:text="⚠️ Complaint" android:textColor="#E11D48"
                                android:textSize="10sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:cardCornerRadius="14dp" app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Littering in common corridor"
                                    android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_marginBottom="2dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Request #CMP-0016 · Floor 3"
                                    android:textColor="#94A3B8" android:textSize="11sp" />
                            </LinearLayout>
                            <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="24dp"
                                app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#F1F5F9">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:text="Pending" android:textColor="#64748B"
                                    android:textSize="10sp" android:textStyle="bold" />
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginBottom="10dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_thumb_up" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4" android:textColor="#82A6CB" android:textSize="12sp"
                            android:layout_marginEnd="14dp" />
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_comment" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="1 comment" android:textColor="#82A6CB" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="View Details" android:textColor="#3667A6" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── COMPLAINT 4 — Lift · Resolved ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/complaintItem4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <androidx.cardview.widget.CardView android:layout_width="40dp" android:layout_height="40dp"
                            app:cardCornerRadius="13dp" app:cardElevation="0dp" app:cardBackgroundColor="#EEF4FB">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_announcement"
                                app:tint="#214177" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Management" android:textColor="#1E293B"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="5 days ago" android:textColor="#94A3B8" android:textSize="11sp" />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="22dp"
                            app:cardCornerRadius="11dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFE4E6">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:text="⚠️ Complaint" android:textColor="#E11D48"
                                android:textSize="10sp" android:textStyle="bold" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:cardCornerRadius="14dp" app:cardElevation="0dp"
                        app:cardBackgroundColor="#F8FAFC">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Lift doors closing too fast"
                                    android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"
                                    android:layout_marginBottom="2dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Request #CMP-0014 · Block A"
                                    android:textColor="#94A3B8" android:textSize="11sp" />
                            </LinearLayout>
                            <androidx.cardview.widget.CardView android:layout_width="wrap_content" android:layout_height="24dp"
                                app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#DCFCE7">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center" android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:text="Resolved" android:textColor="#16A34A"
                                    android:textSize="10sp" android:textStyle="bold" />
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginBottom="10dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_thumb_up" android:layout_marginEnd="4dp" app:tint="#82A6CB" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Resolved" android:textColor="#16A34A"
                            android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="View Summary" android:textColor="#3667A6" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- RecyclerView for dynamic items -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewComplaints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_complaint" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══ POST BUTTON — File New Complaint ══ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fabFileComplaint"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="26dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#214177">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="20dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_add" android:layout_marginEnd="6dp" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="New Complaint" android:textColor="#FFFFFF" android:textSize="13sp"
                android:textStyle="bold" android:letterSpacing="0.03" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>